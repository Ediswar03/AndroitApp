<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/iv_layanan"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon_orange"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_manage"
        app:tint="@color/orange_primary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_nama_layanan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ganti Oli"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_detail_layanan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shell Helix HX7 5W-30"
            android:textColor="@color/gray_text"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_harga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="Rp 250.000"
        android:textColor="@color/black"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/cb_layanan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        android:buttonTint="@color/orange_primary" />

</LinearLayout>