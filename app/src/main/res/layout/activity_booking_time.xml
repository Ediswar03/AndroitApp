<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    tools:context=".BookingTimeActivity">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/primary_blue"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/title_booking_service"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Progress Steps -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <!-- Step 1 -->
                <LinearLayout
                    android:id="@+id/step1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@id/step2"
                    app:layout_constraintHorizontal_chainStyle="spread_inside"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_step_inactive"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/accent_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/step_layanan"
                        android:textColor="@color/text_grey"
                        android:textSize="10sp" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="@color/border_color"
                    app:layout_constraintBottom_toBottomOf="@id/step1"
                    app:layout_constraintEnd_toStartOf="@id/step2"
                    app:layout_constraintStart_toEndOf="@id/step1"
                    app:layout_constraintTop_toTopOf="@id/step1"
                    android:layout_marginBottom="16dp"/>

                <!-- Step 2 -->
                <LinearLayout
                    android:id="@+id/step2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@id/step3"
                    app:layout_constraintStart_toEndOf="@id/step1"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_step_active"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/step_waktu"
                        android:textColor="@color/accent_blue"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="@color/border_color"
                    app:layout_constraintBottom_toBottomOf="@id/step2"
                    app:layout_constraintEnd_toStartOf="@id/step3"
                    app:layout_constraintStart_toEndOf="@id/step2"
                    app:layout_constraintTop_toTopOf="@id/step2"
                    android:layout_marginBottom="16dp"/>

                <!-- Step 3 -->
                <LinearLayout
                    android:id="@+id/step3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@id/step4"
                    app:layout_constraintStart_toEndOf="@id/step2"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_step_inactive"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/text_grey" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/step_lokasi"
                        android:textColor="@color/text_grey"
                        android:textSize="10sp" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="@color/border_color"
                    app:layout_constraintBottom_toBottomOf="@id/step3"
                    app:layout_constraintEnd_toStartOf="@id/step4"
                    app:layout_constraintStart_toEndOf="@id/step3"
                    app:layout_constraintTop_toTopOf="@id/step3"
                    android:layout_marginBottom="16dp"/>

                <!-- Step 4 -->
                <LinearLayout
                    android:id="@+id/step4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/step3"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_step_inactive"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="@color/text_grey" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/step_konfirmasi"
                        android:textColor="@color/text_grey"
                        android:textSize="10sp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Pilih Tanggal Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Pilih Tanggal"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Date Item 1 -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_white_stroke_rounded"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sel"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="21 Mei"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Date Item 2 (Selected) -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_blue_rounded"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rab"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="22 Mei"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Date Item 3 -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_white_stroke_rounded"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kam"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="23 Mei"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Date Item 4 -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_white_stroke_rounded"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jum"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="24 Mei"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Date Item 5 -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_white_stroke_rounded"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sab"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="25 Mei"
                            android:textColor="@color/text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Pilih Jam Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Pilih Jam"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="3"
                android:columnOrderPreserved="false"
                android:useDefaultMargins="false">

                <!-- Time Item 08:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="08:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <!-- Time Item 09:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="09:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <!-- Time Item 10:00 (Selected) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_blue_rounded"
                    android:gravity="center"
                    android:text="10:00"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <!-- Time Item 11:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="11:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <!-- Time Item 13:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="13:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <!-- Time Item 14:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="14:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <!-- Time Item 15:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="15:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <!-- Time Item 16:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="16:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <!-- Time Item 17:00 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_white_stroke_rounded"
                    android:gravity="center"
                    android:text="17:00"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnLanjutkan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:background="@drawable/bg_blue_rounded"
        android:text="@string/btn_lanjutkan"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
