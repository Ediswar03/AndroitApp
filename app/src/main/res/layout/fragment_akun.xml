<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Profile Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/orange_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="Foto Profil"
            android:src="@android:drawable/ic_menu_myplaces"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Andi Pratama"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0812 3456 7890"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="andi.pratama@email.com"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Pengaturan"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="@color/white" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Menu Items -->
            <include layout="@layout/item_menu_akun" android:id="@+id/menu_kendaraan" />
            <include layout="@layout/item_menu_akun" android:id="@+id/menu_pembayaran" />
            <include layout="@layout/item_menu_akun" android:id="@+id/menu_alamat" />
            <include layout="@layout/item_menu_akun" android:id="@+id/menu_bantuan" />
            <include layout="@layout/item_menu_akun" android:id="@+id/menu_syarat" />
            <include layout="@layout/item_menu_akun" android:id="@+id/menu_tentang" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Keluar"
                android:textColor="@color/orange_primary"
                android:textAllCaps="false"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/orange_primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>