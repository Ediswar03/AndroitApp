<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.autoserviceapp.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_layanan"
            app:destination="@id/navigation_layanan" />
        <action
            android:id="@+id/action_home_to_booking"
            app:destination="@id/navigation_booking" />
    </fragment>

    <fragment
        android:id="@+id/navigation_booking"
        android:name="com.example.autoserviceapp.ui.booking.BookingFragment"
        android:label="Booking"
        tools:layout="@layout/fragment_booking">
        <action
            android:id="@+id/action_booking_to_jadwal"
            app:destination="@id/navigation_jadwal" />
    </fragment>

    <fragment
        android:id="@+id/navigation_jadwal"
        android:name="com.example.autoserviceapp.ui.booking.JadwalFragment"
        android:label="Pilih Jadwal"
        tools:layout="@layout/fragment_jadwal">
        <action
            android:id="@+id/action_jadwal_to_konfirmasi"
            app:destination="@id/navigation_konfirmasi" />
    </fragment>

    <fragment
        android:id="@+id/navigation_konfirmasi"
        android:name="com.example.autoserviceapp.ui.booking.KonfirmasiFragment"
        android:label="Konfirmasi"
        tools:layout="@layout/fragment_konfirmasi">
        <action
            android:id="@+id/action_konfirmasi_to_detail"
            app:destination="@id/navigation_booking_detail" />
    </fragment>

    <fragment
        android:id="@+id/navigation_booking_detail"
        android:name="com.example.autoserviceapp.ui.booking.BookingDetailFragment"
        android:label="Detail Booking"
        tools:layout="@layout/fragment_booking_detail" />

    <fragment
        android:id="@+id/navigation_riwayat"
        android:name="com.example.autoserviceapp.ui.riwayat.RiwayatFragment"
        android:label="Riwayat"
        tools:layout="@layout/fragment_riwayat" />

    <fragment
        android:id="@+id/navigation_akun"
        android:name="com.example.autoserviceapp.ui.akun.AkunFragment"
        android:label="Akun"
        tools:layout="@layout/fragment_akun">
        <action
            android:id="@+id/action_akun_to_kendaraan"
            app:destination="@id/navigation_kendaraan" />
    </fragment>

    <fragment
        android:id="@+id/navigation_kendaraan"
        android:name="com.example.autoserviceapp.ui.akun.KendaraanFragment"
        android:label="Kendaraan Saya"
        tools:layout="@layout/fragment_kendaraan" />

    <fragment
        android:id="@+id/navigation_layanan"
        android:name="com.example.autoserviceapp.ui.layanan.LayananFragment"
        android:label="Layanan"
        tools:layout="@layout/fragment_layanan">
        <action
            android:id="@+id/action_layanan_to_bengkel"
            app:destination="@id/navigation_bengkel" />
    </fragment>

    <fragment
        android:id="@+id/navigation_bengkel"
        android:name="com.example.autoserviceapp.ui.bengkel.BengkelFragment"
        android:label="Pilih Bengkel"
        tools:layout="@layout/fragment_bengkel" />
</navigation>